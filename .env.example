# Database (Railway PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Site URL for SEO (sitemap, canonical, OG)
NEXT_PUBLIC_SITE_URL="https://malamih.net"

# Admin authentication (used by seed script)
ADMIN_EMAIL="admin@malamih.net"
ADMIN_PASSWORD="change-me"

# Session signing — required in production (min 32 characters)
SESSION_SECRET="change-this-to-a-long-random-secret-in-production-min-32-chars"

# Node environment
NODE_ENV="production"

# Cloudflare R2 (production uploads — optional locally for dev fallback to public/uploads)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Optional: fallback admin notification email if not set in CMS Integrations
# NOTIFY_EMAIL="admin@malamih.net"
